    "delete_folder_confirmation_message" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@ items will be moved to Uncategorized. Delete group \"%2$@\"?"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このグループ内の %1$@ 件は未分類へ移ります。「%2$@」を削除しますか？"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "其中 %1$@ 条记录将移回「未分组」。确定删除分组「%2$@」？"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "其中 %1$@ 條記錄將移回「未分組」。確定刪除分組「%2$@」？"
          }
        }
      }
    },
