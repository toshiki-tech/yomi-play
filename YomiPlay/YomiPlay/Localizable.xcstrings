    "could_not_recognize_speech_please_check_that_the_audio_contains_japanese_speech" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Could not recognize speech. Please check that the audio contains Japanese speech."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "音声を認識できませんでした。音声ファイルに日本語の音声が含まれているか確認してください。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "无法识别语音。请确认音频文件中包含日语语音。"
