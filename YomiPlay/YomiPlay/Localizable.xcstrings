    "home_subtitle_choice_message" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If you have a matching subtitle file, you can import it directly and skip speech recognition.\nYOMI format preserves furigana and translation data."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "対応する字幕ファイルがある場合、直接インポートして音声認識をスキップできます。\nYOMI 形式は振り仮名や翻訳データを完全に保持します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果有对应的字幕文件，可以直接导入，跳过语音识别。\nYOMI格式包含完整注音和翻译数据。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
